#!/bin/bash

source "$CONFIG_DIR/colors.sh"
PLUGIN_DIR="$CONFIG_DIR/plugins"

##### Bar Appearance #####

sketchybar --bar position=top height=40 \
          blur_radius=10 margin=10 y_offset=8 corner_radius=12 \
          border_color=$BAR_BORDER_COLOR \
          border_width=2 \
          shadow=on \
          color=$BAR_COLOR

##### Changing Defaults #####

default=(
  padding_left=5
  padding_right=5
  icon.font="Hack Nerd Font:Regular:15.0"
  label.font="SF Pro:Semibold:15.0"
  icon.color=$WHITE
  label.color=$WHITE
  icon.padding_left=10
  icon.padding_right=0
  label.padding_left=10
  label.padding_right=10
  background.corner_radius=5
  background.color=$ITEM_BG_COLOR
  background.height=24
)
sketchybar --default "${default[@]}"

##### Left Items #####

sketchybar --add event aerospace_workspace_change

##### Workspaces #####

TOTAL_SPACES=9
MONITOR_COUNT=$(aerospace list-monitors 2>/dev/null | wc -l | tr -d ' ')
[ "$MONITOR_COUNT" -lt 1 ] && MONITOR_COUNT=1
SPACES_PER_MONITOR=$(( (TOTAL_SPACES + MONITOR_COUNT - 1) / MONITOR_COUNT ))

for sid in 1 2 3 4 5 6 7 8 9; do
  display_id=$(( (sid - 1) / SPACES_PER_MONITOR + 1 ))

  sketchybar --add item space.$sid left \
             --set space.$sid \
               display="$display_id" \
               drawing=on \
               icon="$sid" \
               icon.padding_left=8 \
               icon.padding_right=0 \
               icon.shadow.distance=4 \
               icon.shadow.color=0xA0000000 \
               label.font="sketchybar-app-font:Regular:16.0" \
               label.padding_left=0 \
               label.padding_right=20 \
               label.y_offset=-1 \
               label.shadow.drawing=off \
               label.shadow.color=0xA0000000 \
               label.shadow.distance=4 \
               background.color=$ITEM_BG_COLOR \
               background.corner_radius=5 \
               background.drawing=on \
               background.border_color=0xAAFFFFFF \
               background.border_width=0 \
               background.height=25 \
               click_script="aerospace workspace $sid" \
               script="$PLUGIN_DIR/aerospace_workspace.sh $sid" \
             --subscribe space.$sid aerospace_workspace_change
done

# Load app icons on startup, hide empty workspaces
for sid in 1 2 3 4 5 6 7 8 9; do
  apps=$(aerospace list-windows --workspace "$sid" 2>/dev/null \
         | awk -F'|' '{gsub(/^ *| *$/, "", $2); print $2}')
  if [ -n "$apps" ]; then
    icon_strip=" "
    while IFS= read -r app; do
      icon_strip+=" $("$PLUGIN_DIR/icon_map_fn.sh" "$app") "
    done <<< "$apps"
    sketchybar --set space.$sid label="$icon_strip" drawing=on
  else
    sketchybar --set space.$sid drawing=off
  fi
done


##### Center Items #####

# Left of notch
sketchybar --add item music center \
           --set music \
             script="$PLUGIN_DIR/music.sh" \
             icon= \
             label.padding_left=0 \
             icon.padding_right=8 \
             label.color=0xffa6e3a1 \
             icon.color=0xffa6e3a1 \
             click_script="open -a Spotify" \
             update_freq=2 \
             width=220 \
             background.drawing=off \
           --subscribe music media_change

# Invisible spacer — creates notch gap on all displays (adjust width: 200-220 for 14" MBP, 220-250 for 16")
sketchybar --add item center.notch center \
           --set center.notch \
             width=220 \
             icon.drawing=off \
             label.drawing=off \
             background.drawing=off

# Right of notch
sketchybar \
  --add item weather center \
    --set weather \
      script="$PLUGIN_DIR/weather.sh" \
      icon= \
      update_freq=300 \
      label.padding_left=0 \
      icon.padding_right=8 \
      label.color=$WHITE \
      icon.color=$WHITE \
      background.drawing=off \
      click_script="open -a Weather" \
  \
  --add item clock center \
    --set clock \
      update_freq=30 \
      icon.padding_left=10 \
      icon.padding_right=4 \
      label.font="SF Pro:Semibold:13.0" \
      label.padding_left=0 \
      label.padding_right=10 \
      background.drawing=off \
      script="$PLUGIN_DIR/clock.sh"

# Center bracket — visual island spanning both sides of notch
sketchybar --add bracket center.bracket \
             music center.notch weather clock \
           --set center.bracket \
             background.color=$ITEM_BG_COLOR \
             background.corner_radius=8 \
             background.height=26 \
             background.drawing=on

##### Right Items #####

sketchybar \
  --add item volume right \
    --set volume \
      script="$PLUGIN_DIR/volume.sh" \
      padding_right=4 \
      --subscribe volume volume_change mouse.scrolled \
  \
  --add item battery right \
    --set battery \
      update_freq=120 \
      script="$PLUGIN_DIR/battery.sh" \
      padding_right=4 \
      --subscribe battery system_woke power_source_change \
  \
  --add graph cpu_usage right 50 \
     --set cpu_usage script="$PLUGIN_DIR/cpu_usage.sh" \
      update_freq=5 \
      label.color=0xffcba6f7 \
      graph.color=0xffcba6f7 \
      graph.fill_color=0x55cba6f7 \
      graph.line_width=2 \
      icon.drawing=off

##### Force all scripts to run the first time #####
sketchybar --update

sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE=$(aerospace list-workspaces --focused)
