#!/usr/bin/env python3
"""
Extract dominant colors from wallpaper and generate a Base16 flavours scheme.

Usage: generate-wallpaper-theme [image_path]
"""

import subprocess
import re
import sys
from pathlib import Path


# Canonical hues for base08-base0E: red, orange, yellow, green, cyan, blue, magenta.
# Accents stay semantic (red is red) and only borrow saturation/brightness — plus a
# small hue bias — from the wallpaper. base0F is the wallpaper-anchored UI accent.
ACCENT_HUES = [0, 30, 55, 120, 185, 220, 285]
MAX_HUE_BIAS = 10       # max degrees an accent may drift toward the wallpaper hue
REAL_COLOR_TOLERANCE = 15  # use an extracted color's hue when this close to canonical
MIN_HUE_SEPARATION = 15    # real hues must be this far from already-picked accents


def get_dominant_colors(image_path, n=32):
    try:
        result = subprocess.run(
            [
                "magick", str(image_path),
                "+dither", "-colors", str(n),
                "-unique-colors", "txt:-",
            ],
            capture_output=True, text=True, check=True, timeout=90,
        )
    except FileNotFoundError:
        print("Error: 'magick' not found. Install ImageMagick: brew install imagemagick", file=sys.stderr)
        sys.exit(1)
    except subprocess.TimeoutExpired:
        print("Error: magick timed out (image too large or slow?)", file=sys.stderr)
        sys.exit(1)
    except subprocess.CalledProcessError as e:
        print(f"Error: magick failed: {e.stderr.strip() or e}", file=sys.stderr)
        sys.exit(1)
    return list(dict.fromkeys(re.findall(r"#([0-9A-Fa-f]{6})", result.stdout)))


def hex_to_rgb(h):
    return tuple(int(h[i:i+2], 16) for i in (0, 2, 4))


def luminance(h):
    r, g, b = hex_to_rgb(h)
    return 0.2126 * r + 0.7152 * g + 0.0722 * b


def saturation(h):
    r, g, b = [x / 255.0 for x in hex_to_rgb(h)]
    cmax, cmin = max(r, g, b), min(r, g, b)
    return (cmax - cmin) / cmax if cmax > 0 else 0


def hue(h):
    r, g, b = [x / 255.0 for x in hex_to_rgb(h)]
    cmax = max(r, g, b)
    cmin = min(r, g, b)
    delta = cmax - cmin
    if delta == 0:
        return 0
    if cmax == r:
        return (60 * ((g - b) / delta)) % 360
    if cmax == g:
        return 60 * ((b - r) / delta + 2)
    return 60 * ((r - g) / delta + 4)


def vibrance(h):
    """Combined score: saturation * sqrt(luminance/255). Prefers vivid, visible colors."""
    return saturation(h) * ((luminance(h) / 255) ** 0.5)


def signed_hue_diff(a, b):
    """Shortest signed angular distance from b to a, in (-180, 180]."""
    d = (a - b) % 360
    return d - 360 if d > 180 else d


def hsv_to_hex(h, s, v):
    """Convert HSV (h:0-360, s:0-1, v:0-1) to hex string."""
    h = h % 360
    c = v * s
    x = c * (1 - abs((h / 60) % 2 - 1))
    m = v - c
    if h < 60:    r, g, b = c, x, 0
    elif h < 120: r, g, b = x, c, 0
    elif h < 180: r, g, b = 0, c, x
    elif h < 240: r, g, b = 0, x, c
    elif h < 300: r, g, b = x, 0, c
    else:         r, g, b = c, 0, x
    return "{:02X}{:02X}{:02X}".format(round((r+m)*255), round((g+m)*255), round((b+m)*255))


def rgb_to_hsv(h):
    r, g, b = [x / 255.0 for x in hex_to_rgb(h)]
    cmax = max(r, g, b)
    cmin = min(r, g, b)
    delta = cmax - cmin
    s = delta / cmax if cmax > 0 else 0
    return hue(h), s, cmax


def clamp(x, lo, hi):
    return max(lo, min(hi, x))


def build_accents(colors):
    """base08-0E: canonical semantic hues, harmonized with the wallpaper.

    Every accent is synthesized at a uniform saturation/brightness band taken
    from the wallpaper's most vibrant color, so no single slot dominates and
    dull slots don't disappear. The hue is canonical (red stays red) with at
    most MAX_HUE_BIAS degrees of drift toward the wallpaper hue — unless the
    wallpaper actually contains a color near the canonical hue, in which case
    that real hue is used. base0F is the pure wallpaper accent for UI chrome
    (window borders, tmux active tab / pane borders, kitty active tab).
    """
    ref = max(colors, key=vibrance)
    h_ref, s_ref, v_ref = rgb_to_hsv(ref)
    s = clamp(s_ref, 0.45, 0.72)
    v = clamp(v_ref, 0.72, 0.92)
    # Greyscale wallpapers have no meaningful hue to bias toward
    bias_strength = min(1.0, s_ref / 0.3)

    vivid = [c for c in colors if saturation(c) > 0.25 and luminance(c) > 60]

    accents = []
    picked_hues = []
    for target in ACCENT_HUES:
        near = [
            c for c in vivid
            if abs(signed_hue_diff(hue(c), target)) <= REAL_COLOR_TOLERANCE
            and all(abs(signed_hue_diff(hue(c), p)) >= MIN_HUE_SEPARATION for p in picked_hues)
        ]
        if near:
            h = hue(max(near, key=vibrance))
        else:
            drift = clamp(signed_hue_diff(h_ref, target), -MAX_HUE_BIAS, MAX_HUE_BIAS)
            h = target + drift * bias_strength
        picked_hues.append(h)
        accents.append(hsv_to_hex(h, s, v))

    if s_ref < 0.15:
        wallpaper_accent = hsv_to_hex(220, 0.5, 0.85)  # greyscale fallback: blue
    else:
        wallpaper_accent = hsv_to_hex(h_ref, clamp(s_ref, 0.60, 0.85), clamp(v_ref, 0.80, 0.95))
    accents.append(wallpaper_accent)
    return accents


# base04-07 are text/foreground colors: keep the wallpaper's warmth but cap
# saturation progressively so body text reads as tinted grey, not a solid color.
FG_SATURATION_CAPS = {4: 0.35, 5: 0.28, 6: 0.22, 7: 0.16}


def build_scheme(colors):
    by_lum = sorted(colors, key=luminance)

    # base00-07: backgrounds to foregrounds (darkest → lightest)
    n = len(by_lum)
    indices = [int(round(i * (n - 1) / 7)) for i in range(8)]
    backgrounds = [by_lum[i] for i in indices]

    for i, cap in FG_SATURATION_CAPS.items():
        h, s, v = rgb_to_hsv(backgrounds[i])
        backgrounds[i] = hsv_to_hex(h, min(s, cap), max(v, 0.70 + 0.05 * (i - 4)))

    return backgrounds + build_accents(colors)


def main():
    dotfiles = Path(__file__).resolve().parent.parent
    image_path = Path(sys.argv[1]) if len(sys.argv) > 1 else dotfiles / "wallpaper" / "wallpaper.jpg"

    if not image_path.exists():
        print(f"Error: image not found: {image_path}", file=sys.stderr)
        sys.exit(1)

    print(f"Extracting colors from {image_path}...")
    colors = get_dominant_colors(image_path, n=32)

    if len(colors) < 8:
        print(f"Warning: only {len(colors)} colors extracted, results may be poor")
        while len(colors) < 16:
            colors.append("000000")

    bases = build_scheme(colors)

    while len(bases) < 16:
        bases.append("000000")

    scheme_dir = Path.home() / "Library/Application Support/flavours/base16/schemes/wallpaper"
    scheme_dir.mkdir(parents=True, exist_ok=True)
    scheme_file = scheme_dir / "wallpaper.yaml"

    keys = [f"base{i:02X}" for i in range(16)]
    lines = ['scheme: "Wallpaper"', 'author: "Generated from wallpaper"']
    for key, color in zip(keys, bases):
        lines.append(f'{key}: "{color.upper()}"')

    scheme_file.write_text("\n".join(lines) + "\n")
    print(f"Scheme written: {scheme_file}")
    print("Colors:")
    for key, color in zip(keys, bases):
        print(f"  {key}: #{color.upper()}")


if __name__ == "__main__":
    main()
