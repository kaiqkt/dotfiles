root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{kt,kts}]
indent_style = space
indent_size = 4

[*.java]
indent_style = space
indent_size = 4

[*.go]
indent_style = tab
indent_size = 4

[*.{json,yaml,yml,toml}]
indent_style = space
indent_size = 2

[*.{sh,zsh}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
