###############################################################################
# Display
###############################################################################

bg="#{{base00-hex}}"
fg="#{{base05-hex}}"
red="#{{base08-hex}}"
orange="#{{base09-hex}}"
yellow="#{{base0A-hex}}"
blue="#{{base0D-hex}}"
lblue="#{{base0D-hex}}"
green="#{{base0B-hex}}"
cyan="#{{base0C-hex}}"
magenta="#{{base0E-hex}}"
pink="#{{base0E-hex}}"
accent="#{{base0F-hex}}"
grey1="#{{base07-hex}}"
grey2="#{{base07-hex}}"
grey3="#{{base07-hex}}"
grey4="#{{base06-hex}}"
grey5="#{{base06-hex}}"
grey6="#{{base06-hex}}"
grey7="#{{base05-hex}}"
grey8="#{{base05-hex}}"
grey9="#{{base04-hex}}"
grey10="#{{base04-hex}}"
grey11="#{{base03-hex}}"
grey12="#{{base03-hex}}"
grey13="#{{base02-hex}}"
grey13_dark="#{{base02-hex}}"
grey14="#{{base02-hex}}"
grey15="#{{base01-hex}}"
grey16="#{{base01-hex}}"
grey17="#{{base01-hex}}"
grey18="#{{base00-hex}}"
grey19="#{{base00-hex}}"

set -g @mode_indicator_prefix_prompt " WAIT #[default]#[fg=$green]"
set -g @mode_indicator_prefix_mode_style bg=$green,fg=$fg
set -g @mode_indicator_copy_prompt " COPY #[default]#[fg=$blue]"
set -g @mode_indicator_copy_mode_style bg=$blue,fg=$fg
set -g @mode_indicator_sync_prompt " SYNC #[default]#[fg=$red]"
set -g @mode_indicator_sync_mode_style bg=$red,fg=$fg
set -g @mode_indicator_empty_prompt " TMUX #[default]#[fg=$grey12]"
set -g @mode_indicator_empty_mode_style bg=$grey12,fg=$grey7

set -g @route_to_ping "vultr.net"
set -g @online_icon "#[fg=$green]ă€‡"
set -g @offline_icon "#[fg=$red]ă€‡"

set -g status on
set -g status-justify centre
set -g status-position bottom
set -g status-left-length 90
set -g status-right-length 90
set -g status-style "bg=$bg"
set -g window-style "fg=$grey10,bg=$bg"
set -g window-active-style "fg=$fg,bg=$bg"

set -g message-style bg=$accent,fg=$bg
set -g pane-border-style fg=$grey11
set -g pane-active-border-style fg=$accent

set -g popup-style "bg=$bg,fg=$fg"
set -g popup-border-style "fg=$accent"
set -g popup-border-lines rounded
setw -g window-status-separator ""

#################################### FORMAT ####################################
set -g status-left "#{tmux_mode_indicator} "
set -g status-right "#[fg=$grey11]#{online_status}   #[fg=$grey11]%R"

setw -g window-status-format "#[fg=$grey11,nobold,nounderscore,noitalics] #[fg=$grey11] #I #W #[fg=$grey11,nobold,nounderscore,noitalics]"
setw -g window-status-current-format "#[fg=$grey11,nobold,nounderscore,noitalics] #[fg=$accent] #I #W #[fg=$grey11,nobold,nounderscore,noitalics]"
